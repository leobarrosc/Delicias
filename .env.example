# Conexão usada pela aplicação em runtime (Transaction Pooler do Supabase, porta 6543).
# Obrigatória tanto no desenvolvimento local quanto nas variáveis de ambiente da Vercel.
DATABASE_URL="postgresql://postgres.PROJECT_REF:SUA_SENHA@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexão usada pela CLI do Prisma (db push, migrations) — Session Pooler, porta 5432.
# Necessária localmente; na Vercel só é preciso se você rodar migrations no build.
DIRECT_URL="postgresql://postgres.PROJECT_REF:SUA_SENHA@REGION.pooler.supabase.com:5432/postgres"
