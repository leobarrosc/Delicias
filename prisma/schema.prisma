generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PedidoStatus {
  EM_ORCAMENTO
  PRODUCAO
  CONCLUIDO
  CANCELADO
}

enum MovimentoEstoqueTipo {
  ENTRADA
  SAIDA
  AJUSTE
}

model User {
  id                String              @id @default(cuid())
  nome              String
  email             String              @unique
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  insumos           Insumo[]
  insumoCompras     InsumoCompra[]
  marcas            Marca[]
  receitas          Receita[]
  receitaItens      ReceitaItem[]
  categoriasReceita CategoriaReceita[]
  clientes          Cliente[]
  aniversariantes   Aniversariante[]
  pedidos           Pedido[]
  pedidoItens       PedidoItem[]
  movimentosEstoque MovimentoEstoque[]
  configuracao      ConfiguracaoUsuario?
}

model Insumo {
  id                String              @id @default(cuid())
  userId            String
  nome              String
  marcaId           String?
  fotoUrl           String?
  categoria         String
  // O produto como existe na prateleira: uma embalagem de 395 g, 1 L etc.
  // As compras registram quantas embalagens foram compradas e por quanto.
  conteudoEmbalagem Decimal             @default(1) @db.Decimal(12, 3)
  unidadeEmbalagem  String              @default("unidade")
  unidadeBase       String
  custoUnitarioBase Decimal             @default(0) @db.Decimal(12, 4)
  estoqueAtual      Decimal?            @db.Decimal(12, 3)
  estoqueMinimo     Decimal?            @db.Decimal(12, 3)
  dataUltimaCompra  DateTime?
  ativo             Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  marcaRef          Marca?              @relation(fields: [marcaId], references: [id], onDelete: SetNull)
  receitaItens      ReceitaItem[]
  movimentosEstoque MovimentoEstoque[]
  compras           InsumoCompra[]

  @@index([userId])
  @@index([ativo])
  @@index([marcaId])
}

model Marca {
  id        String   @id @default(cuid())
  userId    String
  nome      String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  insumos   Insumo[]

  @@unique([userId, nome])
  @@index([userId])
}

model CategoriaReceita {
  id        String    @id @default(cuid())
  userId    String
  nome      String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  receitas  Receita[]

  @@unique([userId, nome])
  @@index([userId])
}

model ConfiguracaoUsuario {
  userId              String   @id
  fretePadrao         Decimal  @default(0) @db.Decimal(12, 2)
  mensagemAniversario String   @default("Olá, tudo bem? Vi aqui que {ocasiao_ou_aniversario} de {aniversariante} está chegando e queria te mostrar algumas opções de doces/bolos para a data.")
  mensagemPedido      String   @default("Olá {cliente}! Passando para confirmar os detalhes do seu pedido. Qualquer coisa, é só chamar.")
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InsumoCompra {
  id                   String   @id @default(cuid())
  userId               String
  insumoId             String
  quantidadeEmbalagens Decimal  @db.Decimal(12, 3)
  precoTotal           Decimal  @db.Decimal(12, 2)
  dataCompra           DateTime @default(now())
  observacao           String?
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  insumo               Insumo   @relation(fields: [insumoId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([insumoId, dataCompra])
}

model Receita {
  id                           String        @id @default(cuid())
  userId                       String
  nome                         String
  fotoUrl                      String?
  categoriaId                  String?
  rendimento                   Int?
  custoTotal                   Decimal       @default(0) @db.Decimal(12, 2)
  custoTotalAtual              Decimal       @default(0) @db.Decimal(12, 2)
  custoPorUnidade              Decimal       @default(0) @db.Decimal(12, 2)
  atualizarCustoAutomaticamente Boolean      @default(true)
  ativo                        Boolean       @default(true)
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
  user                         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoria                    CategoriaReceita? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  itens                        ReceitaItem[]
  pedidoItens                  PedidoItem[]

  @@index([userId])
  @@index([ativo])
  @@index([categoriaId])
}

model ReceitaItem {
  id         String   @id @default(cuid())
  userId     String
  receitaId  String
  insumoId   String
  quantidade Decimal  @db.Decimal(12, 3)
  unidade    String
  custoTotal Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  receita    Receita  @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  insumo     Insumo   @relation(fields: [insumoId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([receitaId])
  @@index([insumoId])
}

model Cliente {
  id              String           @id @default(cuid())
  userId          String
  nome            String
  telefone        String?
  whatsapp        String?
  email           String?
  dataNascimento  DateTime?
  endereco        String?
  observacoes     String?
  ativo           Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  aniversariantes Aniversariante[]
  pedidos         Pedido[]

  @@index([userId])
  @@index([ativo])
}

model Aniversariante {
  id          String   @id @default(cuid())
  userId      String
  clienteId   String
  nome        String
  // Dia e mês separados porque nem sempre o ano de nascimento é conhecido;
  // um DATE obrigaria a inventar anos falsos e complicaria a recorrência.
  dia         Int
  mes         Int
  ano         Int?
  ocasiao     String   @default("Aniversário")
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pedidos     Pedido[]

  @@index([userId, mes, dia])
  @@index([clienteId])
}

model Pedido {
  id                    String        @id @default(cuid())
  userId                String
  clienteId             String?
  aniversarianteId      String?
  status                PedidoStatus  @default(EM_ORCAMENTO)
  dataPedido            DateTime      @default(now())
  dataEntrega           DateTime?
  multiplicadorLucro    Decimal       @default(2) @db.Decimal(6, 2)
  freteSnapshot         Decimal       @default(0) @db.Decimal(12, 2)
  custoTotalSnapshot    Decimal       @default(0) @db.Decimal(12, 2)
  precoSugeridoSnapshot Decimal       @default(0) @db.Decimal(12, 2)
  precoTotalSnapshot    Decimal       @default(0) @db.Decimal(12, 2)
  lucroEstimadoSnapshot Decimal       @default(0) @db.Decimal(12, 2)
  estoqueBaixado        Boolean       @default(false)
  estoqueDevolvido      Boolean       @default(false)
  observacoes           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cliente               Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  aniversariante        Aniversariante? @relation(fields: [aniversarianteId], references: [id], onDelete: SetNull)
  itens                 PedidoItem[]

  @@index([userId])
  @@index([clienteId])
  @@index([aniversarianteId])
  @@index([status])
}

model PedidoItem {
  id                    String   @id @default(cuid())
  userId                String
  pedidoId              String
  receitaId             String?
  descricao             String
  quantidade            Int      @default(1)
  custoUnitarioSnapshot Decimal  @default(0) @db.Decimal(12, 2)
  precoSugeridoUnitarioSnapshot Decimal @default(0) @db.Decimal(12, 2)
  precoUnitarioSnapshot Decimal  @default(0) @db.Decimal(12, 2)
  custoTotalSnapshot    Decimal  @default(0) @db.Decimal(12, 2)
  precoSugeridoTotalSnapshot Decimal @default(0) @db.Decimal(12, 2)
  precoTotalSnapshot    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedido                Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  receita               Receita? @relation(fields: [receitaId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([pedidoId])
  @@index([receitaId])
}

model MovimentoEstoque {
  id         String              @id @default(cuid())
  userId     String
  insumoId   String
  tipo       MovimentoEstoqueTipo
  quantidade Decimal             @db.Decimal(12, 3)
  custoTotal Decimal?            @db.Decimal(12, 2)
  observacao String?
  createdAt  DateTime            @default(now())
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  insumo     Insumo              @relation(fields: [insumoId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([insumoId])
  @@index([tipo])
}
